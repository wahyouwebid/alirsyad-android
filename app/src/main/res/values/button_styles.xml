    <!--  BORDER  -->

    <style name="Button.Border" parent="Widget.MaterialComponents.Button.OutlinedButton" />

    <style name="Button.Border.Primary">
        <item name="strokeColor">@color/colorPrimary</item>
        <item name="strokeWidth">@dimen/_2sdp</item>
        <item name="android:textColor">@color/colorPrimary</item>
        <item name="cornerRadius">@dimen/_10sdp</item>
    </style>

    <style name="Button.Border.Primary.Small">
        <item name="android:paddingTop">@dimen/_8sdp</item>
