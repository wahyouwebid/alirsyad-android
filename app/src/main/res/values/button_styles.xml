<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Button" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@color/neutral_10</item>
        <item name="android:textAllCaps">false</item>
        <item name="backgroundTint">@color/transparent</item>
    </style>

    <!--  FILL  -->

    <style name="Button.Fill" />

    <style name="Button.Fill.Primary">
        <item name="cornerRadius">@dimen/_10sdp</item>
        <item name="backgroundTint">@color/colorPrimary</item>
    </style>

    <style name="Button.Fill.Primary.Small">
        <item name="android:paddingTop">@dimen/_8sdp</item>
        <item name="android:paddingBottom">@dimen/_8sdp</item>
        <item name="android:paddingEnd">@dimen/_10sdp</item>
        <item name="android:paddingStart">@dimen/_10sdp</item>
        <item name="android:textAppearance">@style/Text.Sm.SemiBold</item>
    </style>

    <style name="Button.Fill.Primary.Medium">
        <item name="android:paddingTop">@dimen/_16sdp</item>
        <item name="android:paddingBottom">@dimen/_16sdp</item>
        <item name="android:paddingEnd">@dimen/_20sdp</item>
        <item name="android:paddingStart">@dimen/_20sdp</item>
        <item name="android:textAppearance">@style/Text.Base.SemiBold</item>
    </style>

    <style name="Button.Fill.Primary.Large">
        <item name="android:paddingTop">@dimen/_20sdp</item>
        <item name="android:paddingBottom">@dimen/_20sdp</item>
        <item name="android:paddingEnd">@dimen/_30sdp</item>
        <item name="android:paddingStart">@dimen/_30sdp</item>
        <item name="android:textAppearance">@style/Text.Sbase.SemiBold</item>
    </style>

    <style name="Button.Fill.Grey">
        <item name="cornerRadius">@dimen/_10sdp</item>
        <item name="backgroundTint">@color/neutral_60</item>
    </style>

    <style name="Button.Fill.Grey.Small">
        <item name="android:paddingTop">@dimen/_8sdp</item>
        <item name="android:paddingBottom">@dimen/_8sdp</item>
