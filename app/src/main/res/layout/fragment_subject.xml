<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.alirsyad.app.component.toolbar.DibToolbarFeatures
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"/>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/_0sdp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/toolbar">

        <LinearLayout
            android:id="@+id/linearLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <EditText
                android:id="@+id/et_search"
                style="@style/searchStroke"
                android:layout_width="match_parent"
                android:layout_height="@dimen/_53sdp"
                android:layout_margin="@dimen/_16sdp"
                android:autofillHints="search"
                android:drawableEnd="@drawable/ic_search"
                android:drawablePadding="@dimen/_8sdp"
                android:enabled="true"
                android:fontFamily="@font/poppins_regular"
                android:hint="@string/title_search_subject"
                android:inputType="text"
                android:paddingStart="@dimen/_18sdp"
                android:paddingTop="@dimen/_10sdp"
                android:paddingEnd="@dimen/_16sdp"
                android:paddingBottom="@dimen/_8sdp"
                android:textColorHint="#7F7F7F"
                android:textSize="@dimen/_14ssp"
                app:layout_constraintTop_toTopOf="parent" />

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_subject_class"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/_38sdp"
                        android:clipToPadding="false"
                        android:paddingEnd="@dimen/_16sdp"
                        android:paddingStart="@dimen/_0sdp"
                        app:layout_constraintTop_toTopOf="parent"/>

                    <com.facebook.shimmer.ShimmerFrameLayout
                        android:id="@+id/sh_subjects_class"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingBottom="@dimen/_8sdp"
                        app:layout_constraintTop_toTopOf="parent">

                        <include layout="@layout/place_holder_subject_class" />

                    </com.facebook.shimmer.ShimmerFrameLayout>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/cv_subject_course"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="@dimen/_16sdp"
                        android:layout_marginTop="@dimen/_16sdp"
                        android:layout_marginRight="@dimen/_16sdp"
                        app:cardCornerRadius="@dimen/_15sdp"
                        app:cardElevation="@dimen/_5sdp"
                        app:layout_constraintTop_toBottomOf="@+id/rv_subject_class">

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/rv_subject_course"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:clipToPadding="false"
                                android:paddingStart="0dp"
                                android:paddingEnd="@dimen/_16sdp"
                                android:layout_marginBottom="@dimen/_16sdp"
                                app:layout_constraintTop_toTopOf="parent"/>

                            <com.facebook.shimmer.ShimmerFrameLayout
                                android:id="@+id/sh_subject_course"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                app:layout_constraintTop_toTopOf="parent">

                                <include layout="@layout/place_holder_course" />

                            </com.facebook.shimmer.ShimmerFrameLayout>
                        </androidx.constraintlayout.widget.ConstraintLayout>

                    </androidx.cardview.widget.CardView>

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/cl_no_data_in_progress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone"
                        app:layout_constraintTop_toBottomOf="@+id/rv_subject_class">

                        <com.airbnb.lottie.LottieAnimationView
                            android:id="@+id/empty_subject_course"
                            android:layout_width="@dimen/_200sdp"
                            android:layout_height="@dimen/_150sdp"
                            android:layout_centerHorizontal="true"
                            android:layout_centerVertical="true"
                            android:layout_marginTop="@dimen/_16sdp"
                            android:visibility="visible"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:lottie_autoPlay="true"
                            app:lottie_loop="true"
                            app:lottie_rawRes="@raw/empty" />

                        <TextView
                            android:layout_width="@dimen/_0sdp"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/regular"
                            android:gravity="center"
                            android:text="@string/title_no_data_module"
                            android:textSize="@dimen/_16ssp"
                            app:layout_constraintEnd_toEndOf="@+id/empty_subject_course"
                            app:layout_constraintStart_toStartOf="@+id/empty_subject_course"
                            app:layout_constraintTop_toBottomOf="@+id/empty_subject_course" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.core.widget.NestedScrollView>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>