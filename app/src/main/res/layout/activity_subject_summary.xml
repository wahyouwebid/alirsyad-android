<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.subjectsummary.SubjectSummaryActivity">

    <com.alirsyad.app.component.toolbar.DibToolbarSubFeatures
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"/>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@+id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.cardview.widget.CardView
                android:id="@+id/cv_summary_of_level"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_16sdp"
                android:layout_marginTop="@dimen/_16sdp"
                android:layout_marginEnd="@dimen/_16sdp"
                app:cardCornerRadius="@dimen/_16sdp"
                app:layout_constraintTop_toTopOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginBottom="@dimen/_20sdp">

                    <TextView
                        android:id="@+id/tv_summary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/_16sdp"
                        android:fontFamily="@font/poppins_bold"
                        android:textSize="@dimen/_16ssp"
                        android:layout_marginTop="@dimen/_20sdp"
                        android:text="@string/title_subject_summary_of_level"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"/>

                    <TextView
                        android:id="@+id/tv_label_easy"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/_16sdp"
                        android:layout_marginTop="@dimen/_16sdp"
                        android:text="@string/title_easy"
                        android:textSize="@dimen/_12ssp"
                        android:textColor="@color/neutral_90"
                        android:fontFamily="@font/poppins_regular"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/tv_summary"/>

                    <TextView
                        android:id="@+id/tv_easy_questions"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins_extra_bold"
                        android:text="0/0"
                        android:textColor="@color/state_color_green"
                        android:textSize="@dimen/_14ssp"
                        android:layout_marginEnd="@dimen/_4sdp"
                        app:layout_constraintBottom_toBottomOf="@+id/tv_label_easy_questions"
                        app:layout_constraintEnd_toStartOf="@+id/tv_label_easy_questions"
                        app:layout_constraintTop_toTopOf="@+id/tv_label_easy_questions" />

                    <TextView
                        android:id="@+id/tv_label_easy_questions"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/_16sdp"
                        android:fontFamily="@font/poppins_regular"
                        android:text="@string/title_question"
                        android:textColor="@color/neutral_80"
                        android:textSize="@dimen/_12ssp"
                        app:layout_constraintBottom_toBottomOf="@+id/tv_label_easy"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@+id/tv_label_easy" />

                    <com.akexorcist.roundcornerprogressbar.RoundCornerProgressBar
                        android:id="@+id/pb_easy"
                        android:layout_width="@dimen/_0sdp"
                        android:layout_height="@dimen/_10sdp"
                        android:layout_marginEnd="@dimen/_16sdp"
                        android:layout_marginTop="@dimen/_5sdp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="@+id/tv_label_easy"
                        app:layout_constraintTop_toBottomOf="@+id/tv_label_easy"
                        app:rcAnimationEnable="true"
                        app:rcAnimationSpeedScale="1"
                        app:rcBackgroundPadding="@dimen/_1sdp"
                        app:rcBackgroundColor="@color/state_color_green_light"
                        app:rcMax="100"
                        app:rcProgress="0"
                        app:rcProgressColor="@color/state_color_green"
                        app:rcRadius="@dimen/_30sdp" />

                    <TextView
                        android:id="@+id/tv_label_medium"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/_16sdp"
                        android:layout_marginTop="@dimen/_25sdp"
                        android:text="@string/title_medium"
                        android:textSize="@dimen/_12ssp"
                        android:textColor="@color/neutral_90"
                        android:fontFamily="@font/poppins_regular"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/pb_easy"/>

                    <TextView
                        android:id="@+id/tv_medium_questions"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins_extra_bold"
                        android:text="0/0"
                        android:textColor="@color/state_color_yellow"
                        android:textSize="@dimen/_14ssp"
                        android:layout_marginEnd="@dimen/_4sdp"
                        app:layout_constraintBottom_toBottomOf="@+id/tv_label_medium_questions"
                        app:layout_constraintEnd_toStartOf="@+id/tv_label_medium_questions"
                        app:layout_constraintTop_toTopOf="@+id/tv_label_medium_questions" />

                    <TextView
                        android:id="@+id/tv_label_medium_questions"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/_16sdp"
                        android:fontFamily="@font/poppins_regular"
                        android:text="@string/title_question"
                        android:textColor="@color/neutral_80"
                        android:textSize="@dimen/_12ssp"
                        app:layout_constraintBottom_toBottomOf="@+id/tv_label_medium"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@+id/tv_label_medium"
                        app:layout_constraintVertical_bias="0.0" />

                    <com.akexorcist.roundcornerprogressbar.RoundCornerProgressBar
                        android:id="@+id/pb_medium"
                        android:layout_width="@dimen/_0sdp"
                        android:layout_height="@dimen/_10sdp"
                        android:layout_marginEnd="@dimen/_16sdp"
                        android:layout_marginTop="@dimen/_5sdp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="@+id/tv_label_medium"
                        app:layout_constraintTop_toBottomOf="@+id/tv_label_medium"
                        app:rcAnimationEnable="true"
                        app:rcAnimationSpeedScale="1"
                        app:rcBackgroundPadding="@dimen/_1sdp"
                        app:rcBackgroundColor="@color/state_color_yellow_light"
                        app:rcMax="100"
                        app:rcProgress="0"
                        app:rcProgressColor="@color/state_color_yellow"
                        app:rcRadius="@dimen/_30sdp" />

                    <TextView
                        android:id="@+id/tv_label_hard"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/_16sdp"
                        android:layout_marginTop="@dimen/_25sdp"
                        android:text="@string/title_hard"
                        android:textSize="@dimen/_12ssp"
                        android:textColor="@color/neutral_90"
                        android:fontFamily="@font/poppins_regular"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/pb_medium"/>

                    <TextView
                        android:id="@+id/tv_hard_questions"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins_extra_bold"
                        android:text="0/0"
                        android:textColor="@color/state_color_red"
                        android:textSize="@dimen/_14ssp"
                        android:layout_marginEnd="@dimen/_4sdp"
                        app:layout_constraintBottom_toBottomOf="@+id/tv_label_hard_questions"
                        app:layout_constraintEnd_toStartOf="@+id/tv_label_hard_questions"
                        app:layout_constraintTop_toTopOf="@+id/tv_label_hard_questions" />

                    <TextView
                        android:id="@+id/tv_label_hard_questions"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/_16sdp"
                        android:fontFamily="@font/poppins_regular"
                        android:text="@string/title_question"
                        android:textColor="@color/neutral_80"
                        android:textSize="@dimen/_12ssp"
                        app:layout_constraintBottom_toBottomOf="@+id/tv_label_hard"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@+id/tv_label_hard"
                        app:layout_constraintVertical_bias="0.0" />

                    <com.akexorcist.roundcornerprogressbar.RoundCornerProgressBar
                        android:id="@+id/pb_hard"
                        android:layout_width="@dimen/_0sdp"
                        android:layout_height="@dimen/_10sdp"
                        android:layout_marginEnd="@dimen/_16sdp"
                        android:layout_marginTop="@dimen/_5sdp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="@+id/tv_label_hard"
                        app:layout_constraintTop_toBottomOf="@+id/tv_label_hard"
                        app:rcAnimationEnable="true"
                        app:rcAnimationSpeedScale="1"
                        app:rcBackgroundPadding="@dimen/_1sdp"
                        app:rcBackgroundColor="@color/state_color_red_light"
                        app:rcMax="100"
                        app:rcProgress="0"
                        app:rcProgressColor="@color/state_color_red"
                        app:rcRadius="@dimen/_30sdp" />

                </androidx.constraintlayout.widget.ConstraintLayout>


            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cv_progress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_16sdp"
                android:layout_marginTop="@dimen/_16sdp"
                android:layout_marginEnd="@dimen/_16sdp"
                app:cardCornerRadius="@dimen/_16sdp"
                app:layout_constraintTop_toBottomOf="@+id/cv_summary_of_level">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginBottom="@dimen/_20sdp">

                    <TextView
                        android:id="@+id/tv_label_type_learning"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/_16sdp"
                        android:fontFamily="@font/poppins_bold"
                        android:textSize="@dimen/_16ssp"
                        android:layout_marginTop="@dimen/_20sdp"
                        android:text="@string/title_type_of_learning"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"/>

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/cl_learning_module"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_16sdp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        app:layout_constraintTop_toBottomOf="@+id/tv_label_type_learning">

                        <ImageView
                            android:id="@+id/iv_learning_module"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/ic_learning_module"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            android:layout_marginStart="@dimen/_16sdp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            android:contentDescription="@string/title_image" />

                        <TextView
                            android:id="@+id/tv_learning_module"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/_14sdp"
                            android:layout_marginEnd="@dimen/_14sdp"
                            android:fontFamily="@font/poppins_bold"
                            android:text="@string/title_learning_module"
                            android:textColor="@color/neutral_100"
                            android:textSize="@dimen/_14ssp"
                            app:layout_constraintBottom_toBottomOf="@+id/iv_learning_module"
                            app:layout_constraintEnd_toStartOf="@+id/iv_arrow_learning_module"
                            app:layout_constraintStart_toEndOf="@+id/iv_learning_module"
                            app:layout_constraintTop_toTopOf="@+id/iv_learning_module" />

                        <ImageView
                            android:id="@+id/iv_arrow_learning_module"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/ic_arrow_rectangle"
                            android:layout_marginEnd="@dimen/_25sdp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            android:contentDescription="@string/title_image" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_marginTop="@dimen/_12sdp"
                            android:layout_marginStart="@dimen/_6sdp"
                            android:layout_marginEnd="@dimen/_16sdp"
                            android:background="@color/neutral_30"
                            app:layout_constraintTop_toBottomOf="@+id/iv_learning_module"
                            app:layout_constraintStart_toEndOf="@+id/iv_learning_module"
                            app:layout_constraintEnd_toEndOf="parent"/>

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/cl_learning_video"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        app:layout_constraintTop_toBottomOf="@+id/cl_learning_module">

                        <ImageView
                            android:id="@+id/iv_learning_video"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/ic_learning_video"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            android:layout_marginStart="@dimen/_16sdp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            android:contentDescription="@string/title_image" />

                        <TextView
                            android:id="@+id/tv_learning_video"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/_14sdp"
                            android:layout_marginEnd="@dimen/_14sdp"
                            android:fontFamily="@font/poppins_bold"
                            android:text="@string/title_learning_video"
                            android:textColor="@color/neutral_100"
                            android:textSize="@dimen/_14ssp"
                            app:layout_constraintBottom_toBottomOf="@+id/iv_learning_video"
                            app:layout_constraintEnd_toStartOf="@+id/iv_arrow_learning_video"
                            app:layout_constraintStart_toEndOf="@+id/iv_learning_video"
                            app:layout_constraintTop_toTopOf="@+id/iv_learning_video" />

                        <ImageView
                            android:id="@+id/iv_arrow_learning_video"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/ic_arrow_rectangle"
                            android:layout_marginEnd="@dimen/_25sdp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            android:contentDescription="@string/title_image" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_marginTop="@dimen/_12sdp"
                            android:layout_marginStart="@dimen/_6sdp"
                            android:layout_marginEnd="@dimen/_16sdp"
                            android:background="@color/neutral_30"
                            app:layout_constraintTop_toBottomOf="@+id/iv_learning_video"
                            app:layout_constraintStart_toEndOf="@+id/iv_learning_video"
                            app:layout_constraintEnd_toEndOf="parent"/>

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/cl_learning_adaptive"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        app:layout_constraintTop_toBottomOf="@+id/cl_learning_video">

                        <ImageView
                            android:id="@+id/iv_learning_adaptive"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/ic_learning_adaptive"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            android:layout_marginStart="@dimen/_16sdp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            android:contentDescription="@string/title_image" />

                        <TextView
                            android:id="@+id/tv_learning_adaptive"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/_14sdp"
                            android:layout_marginEnd="@dimen/_14sdp"
                            android:fontFamily="@font/poppins_bold"
                            android:text="@string/title_learning_adaptive"
                            android:textColor="@color/neutral_100"
                            android:textSize="@dimen/_14ssp"
                            app:layout_constraintBottom_toBottomOf="@+id/iv_learning_adaptive"
                            app:layout_constraintEnd_toStartOf="@+id/iv_arrow_learning_adaptive"
                            app:layout_constraintStart_toEndOf="@+id/iv_learning_adaptive"
                            app:layout_constraintTop_toTopOf="@+id/iv_learning_adaptive" />

                        <ImageView
                            android:id="@+id/iv_arrow_learning_adaptive"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/ic_arrow_rectangle"
                            android:layout_marginEnd="@dimen/_25sdp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            android:contentDescription="@string/title_image" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_marginTop="@dimen/_12sdp"
                            android:layout_marginStart="@dimen/_6sdp"
                            android:layout_marginEnd="@dimen/_16sdp"
                            android:background="@color/neutral_30"
                            app:layout_constraintTop_toBottomOf="@+id/iv_learning_adaptive"
                            app:layout_constraintStart_toEndOf="@+id/iv_learning_adaptive"
                            app:layout_constraintEnd_toEndOf="parent"/>

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/cl_learning_simulation"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        app:layout_constraintTop_toBottomOf="@+id/cl_learning_adaptive">

                        <ImageView
                            android:id="@+id/iv_learning_simulation"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/ic_learning_simulation"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            android:layout_marginStart="@dimen/_16sdp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            android:contentDescription="@string/title_image" />

                        <TextView
                            android:id="@+id/tv_learning_simulation"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/_14sdp"
                            android:layout_marginEnd="@dimen/_14sdp"
                            android:fontFamily="@font/poppins_bold"
                            android:text="@string/title_learning_simulation"
                            android:textColor="@color/neutral_100"
                            android:textSize="@dimen/_14ssp"
                            app:layout_constraintBottom_toBottomOf="@+id/iv_learning_simulation"
                            app:layout_constraintEnd_toStartOf="@+id/iv_arrow_learning_simulation"
                            app:layout_constraintStart_toEndOf="@+id/iv_learning_simulation"
                            app:layout_constraintTop_toTopOf="@+id/iv_learning_simulation" />

                        <ImageView
                            android:id="@+id/iv_arrow_learning_simulation"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/ic_arrow_rectangle"
                            android:layout_marginEnd="@dimen/_25sdp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            android:contentDescription="@string/title_image" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_marginTop="@dimen/_12sdp"
                            android:layout_marginStart="@dimen/_6sdp"
                            android:layout_marginEnd="@dimen/_16sdp"
                            android:background="@color/neutral_30"
                            app:layout_constraintTop_toBottomOf="@+id/iv_learning_simulation"
                            app:layout_constraintStart_toEndOf="@+id/iv_learning_simulation"
                            app:layout_constraintEnd_toEndOf="parent"/>

                    </androidx.constraintlayout.widget.ConstraintLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>