<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="horizontal"
    android:gravity="center_vertical">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_answer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_answer_default"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/rb_answer"
            android:layout_width="@dimen/_25sdp"
            android:layout_height="@dimen/_25sdp"
            tools:text="A"
            android:checked="false"
            android:background="@drawable/ic_rb_default"
            android:gravity="center_vertical"
            android:textColor="@color/neutral_90"
            android:textSize="@dimen/_14ssp"
            android:paddingTop="@dimen/_4sdp"
            android:layout_margin="@dimen/_10sdp"
            app:layout_constraintStart_toStartOf="parent"
            android:fontFamily="@font/poppins_regular"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <TextView
            android:id="@+id/tv_answer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins_regular"
            android:gravity="center_vertical"
            android:textColor="@color/neutral_90"
            android:textSize="@dimen/_14ssp"
            tools:text="Soal Ini harus jawab"
            android:layout_marginStart="@dimen/_10sdp"
            android:layout_marginEnd="@dimen/_20sdp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="@+id/rb_answer"
            app:layout_constraintStart_toEndOf="@+id/rb_answer"
            app:layout_constraintTop_toTopOf="@+id/rb_answer" />

        <com.zanvent.mathview.MathView
            android:id="@+id/tv_answer_math"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins_regular"
            android:gravity="center_vertical"
            android:textColor="@color/neutral_90"
            android:textSize="@dimen/_14ssp"
            android:visibility="gone"
            android:layout_marginStart="@dimen/_10sdp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/rb_answer"
            app:layout_constraintBottom_toBottomOf="@+id/tv_answer"
            app:layout_constraintTop_toTopOf="@+id/tv_answer" />

        <com.makeramen.roundedimageview.RoundedImageView
            android:id="@+id/iv_answer"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/_140sdp"
            android:scaleType="fitStart"
            android:visibility="gone"
            android:minWidth="@dimen/_340sdp"
            android:maxWidth="@dimen/_340sdp"
            android:maxHeight="@dimen/_140sdp"
            app:riv_corner_radius_top_left="@dimen/_10sdp"
            app:riv_corner_radius_bottom_left="@dimen/_10sdp"
            app:riv_corner_radius_bottom_right="@dimen/_10sdp"
            app:riv_corner_radius_top_right="@dimen/_10sdp"
            android:layout_marginStart="@dimen/_10sdp"
            app:layout_constraintStart_toEndOf="@+id/rb_answer"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:contentDescription="@string/title_content_description" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>