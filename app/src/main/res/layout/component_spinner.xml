<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    tools:context=".ui.login.LoginActivity">

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fontFamily="@font/poppins_bold"
        tools:text="Fullname"
        android:layout_marginTop="@dimen/_24sdp"
        android:layout_marginStart="@dimen/_16sdp"
        android:layout_marginEnd="@dimen/_16sdp"
        android:textSize="16sp"
        app:layout_constraintTop_toTopOf="parent"/>

    <TextView
        android:id="@+id/tv_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:autofillHints="Email"
        android:background="@drawable/bg_edit_text_grey"
        android:fontFamily="@font/poppins_regular"
        android:textColorHint="@color/neutral_60"
        android:hint="@string/title_password"
        android:paddingStart="@dimen/_24sdp"
        android:paddingTop="@dimen/_14sdp"
        android:paddingEnd="@dimen/_24sdp"
        android:paddingBottom="@dimen/_14sdp"
        android:textSize="@dimen/_16ssp"
        android:layout_marginStart="@dimen/_16sdp"
        android:layout_marginTop="@dimen/_8sdp"
        android:layout_marginEnd="@dimen/_16sdp"
        app:layout_constraintTop_toBottomOf="@+id/tv_title"
        app:drawableEndCompat="@drawable/ic_spinner" />

    <TextView
        android:id="@+id/tv_error"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/title_edit_text_error"
        android:layout_marginStart="@dimen/_16sdp"
        android:fontFamily="@font/poppins_semi_bold"
        android:layout_marginTop="@dimen/_10sdp"
        android:textColor="@color/state_color_red"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@+id/tv_input"/>

</androidx.constraintlayout.widget.ConstraintLayout>